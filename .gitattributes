# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto

# Standardize on LF for all text files unless otherwise specified
* eol=lf

# Explicitly declare text files that should always have CRLF line endings
*.ps1 text eol=crlf
*.bat text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.pptx binary
*.zip binary
